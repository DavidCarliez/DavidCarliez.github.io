---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "About David Carliez and this security research blog",
	title: "About",
};
---

<PageLayout meta={meta}>
	<h1 class="title mb-12">About</h1>
	<div class="prose prose-sm prose-cactus max-w-none">
		<p>
			I am David Carliez, a security researcher and builder based near Grimbergen. I work on practical vulnerability research,
			bug bounty automation, CVE-quality reporting, AI agent security, Windows LPE, and fuzzing.
		</p>
		<p>
			My preference is simple: prove the bug through the real product path. That means denied controls, bypass controls,
			latest-version validation, honest impact, and artifacts that a maintainer can run.
		</p>
		<p>This blog will collect technical notes on:</p>
		<ul class="list-inside list-disc" role="list">
			<li>AI CLI sandbox and permission boundary bugs</li>
			<li>MCP and tool execution security</li>
			<li>Windows local privilege escalation research</li>
			<li>Fuzzing, crash triage, and exploit primitives</li>
			<li>Bug bounty operations and research automation</li>
		</ul>
	</div>
</PageLayout>
