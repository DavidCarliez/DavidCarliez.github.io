---
import PageLayout from "@/layouts/Base.astro";
import SocialList from "@/components/SocialList.astro";

const meta = {
	description:
		"Security research notes by David Carliez: CVE hunting, AI agent security, sandbox boundaries, Windows LPE, fuzzing, and automation.",
	title: "Home",
};
---

<PageLayout meta={meta}>
	<section>
		<h1 class="title mb-8 text-4xl sm:text-5xl">David Carliez</h1>
		<div class="prose prose-sm prose-cactus max-w-none">
			<p>
				Security researcher focused on finding practical bugs in real software: CVE hunting,
				AI agent security, sandbox permission models, Windows local privilege escalation, fuzzing,
				and bug bounty automation.
			</p>
			<p>
				This site is for concise technical writeups: root cause, exploit primitive, impact boundary,
				and reproduction notes. If a bug is weak, the writeup should say why. If a bug is real,
				the primitive should be obvious.
			</p>
		</div>
		<div class="mt-8">
			<SocialList />
		</div>
	</section>

	<section class="mt-16">
		<h2 class="title mb-6 text-xl">Research areas</h2>
		<ul class="grid gap-4 sm:grid-cols-2" role="list">
			<li class="border-muted rounded border p-4">
				<h3 class="text-accent font-semibold">CVE hunting</h3>
				<p class="text-muted mt-2">Source-guided audits, advisory bypasses, patch gaps, and maintainer-ready proof.</p>
			</li>
			<li class="border-muted rounded border p-4">
				<h3 class="text-accent font-semibold">AI agent security</h3>
				<p class="text-muted mt-2">CLI sandboxes, MCP/tool permissions, command execution, and browser automation boundaries.</p>
			</li>
			<li class="border-muted rounded border p-4">
				<h3 class="text-accent font-semibold">Windows LPE</h3>
				<p class="text-muted mt-2">Local privilege escalation research, n-day validation, drivers, services, and abuse primitives.</p>
			</li>
			<li class="border-muted rounded border p-4">
				<h3 class="text-accent font-semibold">Automation</h3>
				<p class="text-muted mt-2">Bots and pipelines for triage, monitoring, target selection, and reproducible research artifacts.</p>
			</li>
		</ul>
	</section>

	<section class="mt-16">
		<h2 class="title text-accent mb-6 text-xl"><a href={`${import.meta.env.BASE_URL}posts/`}>Blog</a></h2>
		<p class="text-muted">No posts yet. First writeup is being prepared.</p>
	</section>
</PageLayout>
