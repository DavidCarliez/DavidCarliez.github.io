---
import PageLayout from "@/layouts/Base.astro";

const meta = {
	description: "Security research writeups by David Carliez",
	title: "Posts",
};
---

<PageLayout meta={meta}>
	<div class="mb-12 flex items-center gap-3">
		<h1 class="title">Posts</h1>
		<a class="text-accent" href={`${import.meta.env.BASE_URL}rss.xml`} target="_blank">RSS</a>
	</div>
	<p class="text-muted">No posts yet. First writeup is being prepared.</p>
</PageLayout>
