---
const today = new Date();
---

<footer>
	<div>&copy; {today.getFullYear()} David Carliez. Security research notes and technical writeups.</div>
	<div class="social-links">
		<a href="https://github.com/DavidCarliez" target="_blank" rel="noreferrer">GitHub</a>
	</div>
</footer>
<style>
	footer {
		padding: 3em 1em 5em 1em;
		border-top: 1px solid var(--border);
		background: color-mix(in srgb, var(--ctp-crust) 70%, transparent);
		color: var(--ctp-subtext0);
		text-align: center;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: var(--accent);
	}
	.social-links a:hover {
		color: var(--ctp-text);
	}
</style>
